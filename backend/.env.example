# ─── ShopZen Backend — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

PORT=5001

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/shopzen
# Atlas (production):
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/shopzen?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production_min32chars

# ─── Frontend origin (used for CORS in production) ─────────────────────────────
# Set this to your Vercel deployment URL, e.g. https://shopzen.vercel.app
FRONTEND_URL=http://localhost:3000

# ─── Cloudinary (images) ───────────────────────────────────────────────────────
# Create free account at cloudinary.com → Dashboard → copy these 3 values
# Leave blank to use local disk storage (localhost dev only)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (nodemailer — optional) ─────────────────────────────────────────────
# Gmail App Password: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=ShopZen <your_email@gmail.com>
