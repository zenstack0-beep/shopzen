# Copy this file to backend/.env.staging. Never put production secrets here.
APP_ENV=staging
PORT=5002
MONGODB_URI=mongodb://127.0.0.1:27017/shopzen_staging
JWT_SECRET=replace-with-a-long-staging-only-secret
# Must be identical on every API/scheduler instance. Existing installs should initially copy their current JWT_SECRET value here, then keep it unchanged.
SOCIAL_MEDIA_SECRET=replace-with-a-separate-long-social-media-encryption-secret
FRONTEND_URL=http://localhost:3000
EXTRA_ORIGINS=http://localhost:3000

# Keeps "Send to Curfox" fully local. Set false only for one deliberate live courier test.
CURFOX_DRY_RUN=true

# Keep outbound production integrations blank/disabled in staging.
RESEND_API_KEY=
EMAIL_USER=
EMAIL_PASS=
STRIPE_SECRET_KEY=
PAYHERE_MERCHANT_SECRET=
META_ACCESS_TOKEN=
MARKETING_AI_ENABLED=false

# Used by Admin → Products → Research via OpenRouter. Web research returns
# source-backed candidates; an admin must still verify each specification.
OPENROUTER_API_KEY=
# Optional. Keep openrouter/auto unless you want to pin a supported model.
OPENROUTER_RESEARCH_MODEL=openrouter/auto
