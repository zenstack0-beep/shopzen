# ─── ShopZen Frontend — Environment Variables ──────────────────────────────────
# Copy this to .env (localhost dev) or set as Vercel environment variables.

# Leave blank for localhost (React proxy handles /api → localhost:5001)
# Set to your Railway backend URL for production, e.g.:
# REACT_APP_API_URL=https://shopzen-backend.up.railway.app
REACT_APP_API_URL=
