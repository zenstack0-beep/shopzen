        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=1800"
        }
      ]
    },
    {
      "source": "/shop/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
