{
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "https://shopzen-production.up.railway.app/api/seo/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "https://shopzen-production.up.railway.app/api/seo/robots.txt"
    },
    {
      "src": "/product/([^/]+)",
      "dest": "https://shopzen-production.up.railway.app/product/$1"
    },
    {
      "src": "/shop",
      "dest": "https://shopzen-production.up.railway.app/shop"
    },
    {
      "src": "/shop/?(.*)",
      "dest": "https://shopzen-production.up.railway.app/shop?$1"
    },
    {
      "src": "/",
      "dest": "https://shopzen-production.up.railway.app/"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}