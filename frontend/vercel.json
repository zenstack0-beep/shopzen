{
  "redirects": [
    {
      "source": "/api/settings",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/api/settings/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon-96x96.png",
      "permanent": true
    },
    {
      "source": "/shop/:category",
      "destination": "/category/:category",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/sitemap.xml"
    },
    {
      "source": "/api/seo/products-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/products-sitemap.xml"
    },
    {
      "source": "/product-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/product-sitemap.xml"
    },
    {
      "source": "/google-merchant-feed.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/google-merchant-feed.xml"
    },
    {
      "source": "/api/seo/categories-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/categories-sitemap.xml"
    },
    {
      "source": "/api/seo/brands-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/brands-sitemap.xml"
    },
    {
      "source": "/api/seo/pages-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/pages-sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://shopzen-production.up.railway.app/api/seo/robots.txt"
    },
    {
      "source": "/favicon.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon.png"
    },
    {
      "source": "/favicon-16x16.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon-16x16.png"
    },
    {
      "source": "/favicon-32x32.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon-32x32.png"
    },
    {
      "source": "/favicon-96x96.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon-96x96.png"
    },
    {
      "source": "/apple-touch-icon.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/apple-touch-icon.png"
    },
    {
      "source": "/android-chrome-192x192.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/android-chrome-192x192.png"
    },
    {
      "source": "/android-chrome-512x512.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/android-chrome-512x512.png"
    },
    {
      "source": "/api/:path*",
      "destination": "https://shopzen-production.up.railway.app/api/:path*"
    },
    {
      "source": "/",
      "destination": "https://shopzen-production.up.railway.app/"
    },
    {
      "source": "/product/:slug",
      "destination": "https://shopzen-production.up.railway.app/product/:slug"
    },
    {
      "source": "/category/:slug",
      "destination": "https://shopzen-production.up.railway.app/category/:slug"
    },
    {
      "source": "/brand/:slug",
      "destination": "https://shopzen-production.up.railway.app/brand/:slug"
    },
    {
      "source": "/shop",
      "destination": "https://shopzen-production.up.railway.app/shop"
    },
    {
      "source": "/gift-cards",
      "destination": "https://shopzen-production.up.railway.app/gift-cards"
    },
    {
      "source": "/page/:slug",
      "destination": "https://shopzen-production.up.railway.app/page/:slug"
    },
    {
      "source": "/campaign/:slug",
      "destination": "https://shopzen-production.up.railway.app/campaign/:slug"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/register",
      "destination": "/index.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/index.html"
    },
    {
      "source": "/cart",
      "destination": "/index.html"
    },
    {
      "source": "/checkout",
      "destination": "/index.html"
    },
    {
      "source": "/order-success/:id",
      "destination": "/index.html"
    },
    {
      "source": "/track-order/:id",
      "destination": "/index.html"
    },
    {
      "source": "/wishlist",
      "destination": "/index.html"
    },
    {
      "source": "/returns",
      "destination": "/index.html"
    },
    {
      "source": "/account",
      "destination": "/index.html"
    },
    {
      "source": "/my-orders",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "destination": "https://shopzen-production.up.railway.app/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000"
        }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, nosnippet" }
      ]
    },
    {
      "source": "/:private(login|register|forgot-password|cart|checkout|wishlist|returns|account|my-orders)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, nosnippet" }
      ]
    },
    {
      "source": "/order-success/:id",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, nosnippet" }
      ]
    },
    {
      "source": "/track-order/:id",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, nosnippet" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff|woff2|ttf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|webp|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/x-icon"
        }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/favicon-32x32.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/favicon-96x96.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/favicon-16x16.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "image/png" }
      ]
    },
    {
      "source": "/android-chrome-192x192.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "image/png" }
      ]
    },
    {
      "source": "/android-chrome-512x512.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "image/png" }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=1800"
        }
      ]
    },
    {
      "source": "/product/(.*)",
