{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://shopzen-production.up.railway.app/api/seo/robots.txt"
    },
    {
      "source": "/api/:path*",
      "destination": "https://shopzen-production.up.railway.app/api/:path*"
    },
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/favicon-32x32.png",
      "destination": "/favicon-32x32.png"
    },
    {
      "source": "/favicon-16x16.png",
      "destination": "/favicon-16x16.png"
    },
    {
      "source": "/apple-touch-icon.png",
      "destination": "/apple-touch-icon.png"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}