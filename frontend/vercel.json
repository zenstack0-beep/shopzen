{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/sitemap.xml"
    },
    {
      "source": "/api/seo/products-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/products-sitemap.xml"
    },
    {
      "source": "/product-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/product-sitemap.xml"
    },
    {
      "source": "/google-merchant-feed.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/google-merchant-feed.xml"
    },
    {
      "source": "/api/seo/categories-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/categories-sitemap.xml"
    },
    {
      "source": "/api/seo/brands-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/brands-sitemap.xml"
    },
    {
      "source": "/api/seo/pages-sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/pages-sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://shopzen-production.up.railway.app/api/seo/robots.txt"
    },
    {
      "source": "/favicon.ico",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon.ico"
    },
    {
      "source": "/favicon.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon.png"
    },
    {
      "source": "/favicon-16x16.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon-16x16.png"
    },
    {
      "source": "/favicon-32x32.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon-32x32.png"
    },
    {
      "source": "/favicon-96x96.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/favicon-96x96.png"
    },
    {
      "source": "/apple-touch-icon.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/apple-touch-icon.png"
    },
    {
      "source": "/android-chrome-192x192.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/android-chrome-192x192.png"
    },
    {
      "source": "/android-chrome-512x512.png",
      "destination": "https://shopzen-production.up.railway.app/api/settings/android-chrome-512x512.png"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff|woff2|ttf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|webp|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/x-icon"
        }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/favicon-32x32.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/favicon-96x96.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/favicon-16x16.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "image/png" }
      ]
    },
    {
      "source": "/android-chrome-192x192.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "image/png" }
      ]
    },
    {
      "source": "/android-chrome-512x512.png",
