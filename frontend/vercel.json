{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://shopzen-production.up.railway.app/api/seo/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://shopzen-production.up.railway.app/api/seo/robots.txt"
    },
    {
      "source": "/api/:path*",
      "destination": "https://shopzen-production.up.railway.app/api/:path*"
    },
    {
      "source": "/product/:slug",
      "destination": "https://shopzen-production.up.railway.app/product/:slug"
    },
    {
      "source": "/shop",
      "destination": "https://shopzen-production.up.railway.app/shop"
    },
    {
      "source": "/shop/:path*",
      "destination": "https://shopzen-production.up.railway.app/shop/:path*"
    },
    {
      "source": "/",
      "destination": "https://shopzen-production.up.railway.app/"
    },
    {
      "source": "/page/:slug",
      "destination": "https://shopzen-production.up.railway.app/page/:slug"
    },
    {
      "source": "/campaign/:slug",
      "destination": "https://shopzen-production.up.railway.app/campaign/:slug"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}